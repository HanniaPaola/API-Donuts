# === Base de datos (MySQL / MariaDB) ===
# Local: localhost. En Fly (misma VM): 127.0.0.1 (lo fija docker-entrypoint.sh).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=tienda_db

# === JWT ===
SECRET_KEY=genera_una_clave_segura_aqui
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Logging (monitoreo) ===
# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s | %(levelname)s | %(name)s | %(message)s
#
# === Fly.io (API + MariaDB en una máquina) ===
# Crear volumen (misma región que fly.toml → primary_region), luego secrets:
#   fly volumes create mariadb_data --region iad --size 3
#   fly secrets set DB_NAME=tienda_db DB_USER=donideli DB_PASSWORD=... SECRET_KEY=...
# Desplegar desde la raíz del repo API-Donuts:
#   fly launch --no-deploy   # si aún no existe la app; ajusta app en fly.toml
#   fly deploy
